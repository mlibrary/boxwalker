{
  "name": "app",
  "private": "true",
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "arclight": "^1",
    "autoprefixer": "^10.5.0",
    "blacklight-frontend": "8.12.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "sass": "^1.100.0"
  },
  "scripts": {
    "build:css:compile": "sass ./app/assets/stylesheets/bootstrap.scss:./app/assets/builds/bootstrap.css ./app/assets/stylesheets/application.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules --quiet-deps --silence-deprecation=import",
    "build:css:prefix": "postcss ./app/assets/builds/bootstrap.css --use=autoprefixer --output=./app/assets/builds/bootstrap.css && postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:css": "yarn build:css:compile && yarn build:css:prefix",
    "watch:css": "nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"yarn build:css\""
  },
  "browserslist": [
    "defaults"
  ]
}
