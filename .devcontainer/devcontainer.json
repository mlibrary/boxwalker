{
  "name": "boxwalker",
  "dockerComposeFile": ["../compose.yml", "compose.devcontainer.yml"],
  "service": "app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/rails,type=bind,consistency=cached",
  "workspaceFolder": "/rails",
  "initializeCommand": "bash -c 'if [ \"$(uname)\" = \"Darwin\" ]; then SRC=\"$HOME/Library/Application Support/JetBrains\"; else SRC=\"$HOME/.config/JetBrains\"; fi; mkdir -p \"$SRC\"; ln -sfn \"$SRC\" \"$HOME/.jetbrains-devcontainer\"'",
  "mounts": [
    "source=${localEnv:HOME}/.jetbrains-devcontainer,target=/home/rails/.local/share/JetBrains,type=bind,consistency=cached"
  ],
  "overrideCommand": true,
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "26",
      "nodeGypDependencies": false
    },
    "ghcr.io/devcontainers-extra/features/apt-get-packages:1": {
      "packages": ["vim"]
    }
  },
  "forwardPorts": [3000, 8983],
  "postStartCommand": "echo 'Dev container ready. Start the app with: bin/dev (runs the Rails server + CSS watcher on port 3000).'",
  "postCreateCommand": "bin/setup --skip-server",
  "customizations": {
    "jetbrains": {
      "backend": "RubyMine",
      "plugins": [
        "com.github.copilot",
        "com.github.jetbrains.plugins.github_copilot_premium_quota_monitor.github-copilot-premium-quota-monitor-for-ij"
      ]
    }
  }
}
