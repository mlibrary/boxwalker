# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore MacOS system files, which are generated by the operating system and should not be committed to the repository.
.DS_Store

# Ingnore IntelliJ IDEA files, which are used for development environments and should not be committed to the repository.
/.idea/

# Ignore Claude Code local settings.
/.claude/

# Ignore Greg's Agent Framework local settings and agents.
#   This is a symbolic link to the actual directory,
#   which is located outside of the repository.
.agents

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

/app/assets/builds/*
!/app/assets/builds/.keep

/node_modules

# Ignore key files for decrypting credentials and more.
/config/*.key
